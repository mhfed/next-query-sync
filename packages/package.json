{
  "name": "next-query-sync",
  "version": "1.0.0",
  "description": "A lightweight, type-safe URL search params state manager for Next.js",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "next.js",
    "url",
    "search-params",
    "query-string",
    "react",
    "hooks",
    "typescript",
    "nuqs"
  ],
  "author": "",
  "license": "MIT",
  "homepage": "https://github.com/mhfed/next-query-sync#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mhfed/next-query-sync.git"
  },
  "bugs": {
    "url": "https://github.com/mhfed/next-query-sync/issues"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^14.0.0",
    "@types/react": "^18.2.0",
    "jsdom": "^24.0.0",
    "react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
